# Production Environment Variables — betivi
# Copy this file to .env.production (or set these vars in your Vercel project settings).
# Never commit real values to version control.

# ---------------------------------------------------------------------------
# Supabase — required for all database and auth operations
# Find these in your Supabase project: Settings > API
# ---------------------------------------------------------------------------

# The public URL of your Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# The public anon key — safe to expose in the browser (protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ---------------------------------------------------------------------------
# Supabase Service Role — used only by the seed script (never in browser)
# Find this in: Settings > API > service_role key
# WARNING: This key bypasses Row-Level Security. Do not expose it client-side.
# ---------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
